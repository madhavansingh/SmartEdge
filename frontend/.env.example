# Copy this file to .env and fill in your values
# NEVER commit the real .env file

VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Backend URL (used by all API calls from laptop browser)
VITE_API_URL=http://localhost:8000

# Port the backend runs on
VITE_BACKEND_PORT=8000

# Your machine's LAN IP — used to generate QR codes for mobile.
# Run: ipconfig getifaddr en0   (Mac) or  hostname -I  (Linux)
VITE_LAN_IP=192.168.x.x

# ElevenLabs voice ID (no API key needed in frontend)
VITE_ELEVENLABS_VOICE_ID=your_voice_id_here
